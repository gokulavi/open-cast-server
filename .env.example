# ============================================================
# OpenCast Server - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# Agora credentials (get from console.agora.io)
AGORA_APP_ID=your_agora_app_id_here
AGORA_APP_CERTIFICATE=your_agora_app_certificate_here

# Token expiry in seconds (default: 3600 = 1 hour)
AGORA_TOKEN_EXPIRY=3600

# Server port (Railway sets this automatically)
PORT=3000

# Allowed origins for CORS (your app's domain or * for dev)
ALLOWED_ORIGINS=*

# Firebase Admin SDK (get from Firebase Console > Project Settings > Service Accounts)
# Paste the entire JSON content as a single line, or use the file path approach
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_private_key_here
FIREBASE_CLIENT_EMAIL=your_client_email_here
